# Port the signaling server listens on.
PORT=4000

# Comma-separated list of allowed client origins.
# Use "*" for local development. In production set this to your deployed client URL,
# e.g. CLIENT_ORIGIN=https://your-app.vercel.app
CLIENT_ORIGIN=*

# How long an idle room is kept before it is swept (milliseconds). Default: 30 min.
ROOM_TTL_MS=1800000

# Maximum peers per room. 2 = classic 1-to-1 transfer. Raise to enable mesh swarming.
MAX_PEERS=2

# Optional TURN relay for clients behind symmetric NATs (where STUN alone fails).
# TURN only relays already-encrypted traffic; it never sees plaintext file data.
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=user
# TURN_CREDENTIAL=secret
