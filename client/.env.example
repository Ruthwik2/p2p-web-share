# Base URL of the signaling server (no trailing slash).
# In production, set this to your deployed backend, e.g.
#   VITE_SIGNALING_URL=https://relay-signaling.onrender.com
#
# Left unset, the app falls back to the same host on :4000 (LAN testing)
# or http://localhost:4000 (local development).
VITE_SIGNALING_URL=http://localhost:4000
